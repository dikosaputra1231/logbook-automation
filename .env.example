# ============================================================
#  .env.example — Template konfigurasi ISPLA
#  SALIN file ini menjadi ".env" dan isi nilainya
#  JANGAN commit file ".env" ke Git!
# ============================================================

# ============================================================
# SECTION 1: KREDENSIAL
# ============================================================

IPB_USERNAME= UNSERNAME LO
IPB_PASSWORD= PASSWORD LO

# --- URL Portal (ganti jika berbeda) ---
PORTAL_URL=https://studentportal.ipb.ac.id

# --- Path folder yang berisi file CSV dan dokumentasi ---
# Gunakan nama folder relatif terhadap folder proyek, atau path absolut
DOCS_FOLDER=data logbook

# --- File CSV logbook yang aktif ---
# Isi nama file CSV saja (ada di dalam DOCS_FOLDER) atau path absolut
# Jika kosong, skrip otomatis mengambil file CSV pertama di DOCS_FOLDER
CSV_FILE=logbook.csv

# --- URL halaman logbook yang akan diisi ---
# Salin URL dari browser saat membuka halaman Log Aktivitas kegiatan Anda
LOGBOOK_URL=https://studentportal.ipb.ac.id/Kegiatan/LogAktivitasKampusMerdeka

# --- Pengaturan Browser ---
# Set ke "true" untuk menjalankan tanpa tampilan browser (background mode)
HEADLESS=false

# --- Pengaturan Timeout (detik) ---
# Waktu maksimum menunggu elemen muncul di halaman
WAIT_TIMEOUT=20
